# ISAAC Environment Variables

# Required — Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Web search via Brave
BRAVE_API_KEY=

# Optional — Telegram bot gateway
TELEGRAM_BOT_TOKEN=

# Optional — Override default model
# ISAAC_MODEL=claude-sonnet-4-6

# Optional — Custom ISAAC home directory
# ISAAC_HOME=~/.isaac
